<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5, viewport-fit=cover">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="返済プラン">
<meta name="theme-color" content="#1D9E75">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icon-180.png">
<link rel="icon" type="image/png" href="icon-192.png">
<title>返済プラン</title>
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icon-180.png">
<link rel="icon" type="image/png" href="icon-192.png">
<style>
:root{
  --green:#1D9E75; --green-d:#0F6E56; --green-l:#E1F5EE; --green-mid:#9FE1CB;
  --red:#DB444C; --red-d:#9E2A30; --red-l:#FBEAEB;
  --blue:#5BB9CD; --blue-d:#2C7A8C; --blue-l:#E6F4F7;
  --ink:#1c2b27; --ink2:#5b6b66; --ink3:#90a09b;
  --bg:#f4f7f5; --card:#ffffff; --line:#e7eeeb;
  --radius:16px; --shadow:0 2px 14px rgba(20,60,45,.06);
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html{font-size:16px;-webkit-text-size-adjust:100%;text-size-adjust:100%;}
body{
  font-family:-apple-system,BlinkMacSystemFont,"Hiragino Sans","Hiragino Kaku Gothic ProN","Noto Sans JP",sans-serif;
  background:var(--bg); color:var(--ink); line-height:1.5;
  padding-bottom:env(safe-area-inset-bottom);
}
.app{max-width:480px;margin:0 auto;min-height:100vh;background:var(--bg);position:relative;}
.screen{display:none;}
.screen.active{display:block;}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit;}
input,select{font-family:inherit;font-size:1rem;}

/* ===== header ===== */
.hd{background:var(--green);color:#fff;padding:18px 18px 24px;border-radius:0 0 22px 22px;}
.hd-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.hd-title{font-size:.95rem;font-weight:700;letter-spacing:.02em;}
.hd-ico{width:38px;height:38px;border-radius:11px;background:rgba(255,255,255,.16);display:flex;align-items:center;justify-content:center;font-size:1.2rem;}
.hd-label{font-size:.8rem;color:var(--green-l);margin-bottom:4px;}
.hd-amount{font-size:2rem;font-weight:800;letter-spacing:-.01em;}
.hd-amount .yen{font-size:1.1rem;font-weight:700;margin-right:2px;}
.hd-sub{font-size:.78rem;color:var(--green-mid);margin-top:6px;}
.bar{height:10px;background:var(--green-d);border-radius:6px;overflow:hidden;margin-top:14px;position:relative;}
.bar > i{display:block;height:100%;background:var(--green-mid);border-radius:6px;transition:width .5s ease;}
.bar-row{display:flex;justify-content:space-between;margin-top:8px;font-size:.74rem;color:var(--green-mid);}

/* ===== body ===== */
.body{padding:14px 14px 90px;}
.sec-h{display:flex;align-items:center;justify-content:space-between;margin:18px 4px 10px;}
.sec-h h2{font-size:.95rem;font-weight:700;}
.sec-h .note{font-size:.72rem;color:var(--ink3);}

.card{background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);}
.lender{display:flex;align-items:center;gap:11px;padding:13px 14px;background:var(--card);border-radius:14px;box-shadow:var(--shadow);margin-bottom:9px;width:100%;text-align:left;}
.lender:active{transform:scale(.99);}
.av{width:40px;height:40px;border-radius:12px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:1rem;flex-shrink:0;}
.lender .mid{flex:1;min-width:0;}
.lender .nm{font-size:.95rem;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.tag{display:inline-block;font-size:.66rem;font-weight:700;padding:2px 8px;border-radius:8px;margin-top:3px;}
.tag.l-link{background:var(--green-l);color:var(--green-d);}
.tag.l-fix{background:var(--blue-l);color:var(--blue-d);}
.lender .rt{text-align:right;flex-shrink:0;}
.lender .rt .rm{font-size:.95rem;font-weight:800;}
.lender .rt .pc{font-size:.68rem;margin-top:2px;color:var(--ink3);}

.add{display:flex;align-items:center;justify-content:center;gap:6px;padding:13px;border:1.5px dashed var(--red);border-radius:14px;color:var(--red);font-size:.9rem;font-weight:700;width:100%;margin-top:4px;}
.add:active{background:var(--red-l);}

/* encouragement */
.cheer{display:flex;gap:11px;align-items:flex-start;background:var(--red-l);border-radius:14px;padding:13px 14px;margin:14px 0 4px;}
.cheer .ico{font-size:1.4rem;line-height:1;}
.cheer .t1{font-size:.92rem;font-weight:800;color:var(--red-d);}
.cheer .t2{font-size:.76rem;color:var(--red);margin-top:3px;}

/* quick buttons */
.quick{display:flex;gap:9px;margin-top:12px;}
.qbtn{flex:1;text-align:center;border-radius:13px;padding:13px 4px;font-size:.74rem;font-weight:700;}
.qbtn .qi{font-size:1.35rem;display:block;margin-bottom:5px;}
.q-red{background:var(--red-l);color:var(--red-d);}
.q-blue{background:var(--blue-l);color:var(--blue-d);}
.q-green{background:var(--green-l);color:var(--green-d);}

/* metrics */
.mrow{display:flex;gap:9px;margin-top:10px;}
.metric{flex:1;border-radius:13px;padding:11px 13px;}
.metric .ml{font-size:.72rem;font-weight:700;}
.metric .mv{font-size:1.05rem;font-weight:800;margin-top:3px;}
.m-blue{background:var(--blue-l);} .m-blue .ml{color:var(--blue-d);} .m-blue .mv{color:#1E5E6C;}
.m-green{background:var(--green-l);} .m-green .ml{color:var(--green-d);} .m-green .mv{color:#085041;}

/* rule box */
.rule{background:var(--green-l);border-radius:13px;padding:12px 14px;margin:14px 0;}
.rule .rl{font-size:.74rem;font-weight:700;color:var(--green-d);}
.rule .rv{font-size:.95rem;font-weight:800;color:#085041;margin-top:4px;}
.rule .rn{font-size:.72rem;color:var(--green);margin-top:5px;}

/* plan vs actual table */
.tbl{width:100%;}
.tbl .th,.tbl .tr{display:flex;align-items:center;padding:9px 2px;font-size:.8rem;}
.tbl .th{font-size:.7rem;color:var(--ink3);border-bottom:1px solid var(--line);}
.tbl .tr{border-bottom:1px solid var(--line);}
.tbl .tr:last-child{border-bottom:none;}
.tbl .c-m{flex:1;font-weight:600;}
.tbl .c-p{width:80px;text-align:right;color:var(--ink2);}
.tbl .c-a{width:80px;text-align:right;font-weight:700;}
.tbl .c-j{width:34px;text-align:right;}
.ok{color:var(--green);} .miss{color:var(--red);}

/* history rows */
.hrow{display:flex;align-items:center;gap:10px;padding:11px 0;border-bottom:1px solid var(--line);}
.hrow:last-child{border-bottom:none;}
.hbadge{width:34px;height:34px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.05rem;flex-shrink:0;}
.hb-fix{background:var(--green-l);color:var(--green-d);}
.hb-extra{background:var(--red-l);color:var(--red);}
.hrow .hm{flex:1;min-width:0;}
.hrow .hm .h1{font-size:.85rem;font-weight:600;}
.hrow .hm .h2{font-size:.7rem;color:var(--ink3);margin-top:1px;}
.hrow .ha{font-size:.85rem;font-weight:800;}
.hrow .ha.fix{color:var(--green-d);} .hrow .ha.extra{color:var(--red);}
.hdots{font-size:1.1rem;color:var(--ink3);padding:4px;}

/* completion estimate */
.est{background:var(--red-l);border-radius:13px;padding:12px 14px;margin:14px 0;display:flex;gap:10px;align-items:center;}
.est .ei{font-size:1.4rem;}
.est .el{font-size:.78rem;font-weight:800;color:var(--red-d);}
.est .ev{font-size:.72rem;color:var(--red);margin-top:2px;}

/* back / topbar for detail */
.tbar{display:flex;align-items:center;gap:6px;padding:12px 14px 0;}
.tbar button{font-size:.85rem;color:var(--green-d);font-weight:700;display:flex;align-items:center;gap:3px;}
.tbar .sp{flex:1;}
.tbar .show-btn{background:var(--green-l);color:var(--green-d);padding:7px 13px;border-radius:20px;font-size:.78rem;font-weight:700;}
.tbar .show-btn.on{background:var(--red);color:#fff;}

/* business chart */
.chart{display:flex;align-items:flex-end;gap:6px;height:150px;padding:6px 2px 0;}
.col{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;gap:5px;height:100%;}
.col .bb{width:70%;background:linear-gradient(180deg,var(--green),var(--green-mid));border-radius:5px 5px 0 0;min-height:3px;transition:height .4s;}
.col .cl{font-size:.6rem;color:var(--ink3);white-space:nowrap;}
.biz-input{display:flex;align-items:center;gap:8px;padding:9px 0;border-bottom:1px solid var(--line);}
.biz-input .bm{flex:1;font-size:.85rem;font-weight:600;}
.biz-input input{width:130px;padding:7px 9px;border:1px solid var(--line);border-radius:9px;text-align:right;}

/* modal */
.mask{position:fixed;inset:0;background:rgba(15,40,30,.45);display:none;align-items:flex-end;justify-content:center;z-index:50;}
.mask.open{display:flex;}
.sheet{background:#fff;width:100%;max-width:480px;border-radius:22px 22px 0 0;padding:20px 18px calc(20px + env(safe-area-inset-bottom));max-height:90vh;overflow-y:auto;}
.sheet h3{font-size:1.05rem;font-weight:800;margin-bottom:14px;}
.fld{margin-bottom:13px;}
.fld label{display:block;font-size:.78rem;font-weight:700;color:var(--ink2);margin-bottom:5px;}
.fld input,.fld select{width:100%;padding:11px 12px;border:1px solid var(--line);border-radius:11px;background:#fafcfb;}
.fld input:focus,.fld select:focus{outline:none;border-color:var(--green);}
.seg{display:flex;gap:8px;}
.seg button{flex:1;padding:11px;border:1px solid var(--line);border-radius:11px;font-size:.82rem;font-weight:700;color:var(--ink2);background:#fafcfb;}
.seg button.on{background:var(--green);color:#fff;border-color:var(--green);}
.btn-row{display:flex;gap:9px;margin-top:8px;}
.btn{flex:1;padding:13px;border-radius:12px;font-size:.92rem;font-weight:800;text-align:center;}
.btn-main{background:var(--green);color:#fff;}
.btn-ghost{background:var(--green-l);color:var(--green-d);}
.btn-del{background:var(--red-l);color:var(--red);}
.hint{font-size:.72rem;color:var(--ink3);margin-top:4px;}

.empty{text-align:center;padding:30px 16px;color:var(--ink3);font-size:.85rem;}
.show-banner{display:none;background:var(--red);color:#fff;text-align:center;font-size:.72rem;font-weight:700;padding:6px;}
.show-banner.on{display:block;}
</style>
</head>
<body>
<div class="app">
  <div class="show-banner" id="showBanner">相手に見せる表示中 ／ 自分用の操作は隠れています</div>

  <!-- ===== HOME ===== -->
  <div class="screen active" id="s-home">
    <div class="hd">
      <div class="hd-row">
        <span class="hd-title">借入ぜんぶ（自分用）</span>
        <button class="hd-ico" onclick="openSettings()">⚙</button>
      </div>
      <div class="hd-label">残債の合計</div>
      <div class="hd-amount" id="homeTotal">¥0</div>
      <div class="hd-sub" id="homeSub">借入0件</div>
    </div>
    <div class="body">
      <div class="cheer">
        <span class="ico">🔥</span>
        <div>
          <div class="t1" id="cheer1">人は出来ないことで悩まない</div>
          <div class="t2" id="cheer2">今日も前へ。1ヶ月ずつ削っていこう。</div>
        </div>
      </div>

      <div class="sec-h"><h2>借入先</h2><span class="note">タップで詳細</span></div>
      <div id="lenderList"></div>
      <button class="add" onclick="openLender()">＋ 借入先を追加</button>

      <div class="sec-h"><h2>事業計画</h2><span class="note">前倒しの根拠</span></div>
      <button class="lender" onclick="go('biz')">
        <span class="av" style="background:var(--blue)">📈</span>
        <div class="mid"><div class="nm">パーソナル売上の成長計画</div><span class="tag l-fix">相手に見せられる</span></div>
        <span class="hdots">›</span>
      </button>
    </div>
  </div>

  <!-- ===== LENDER DETAIL ===== -->
  <div class="screen" id="s-lender">
    <div class="tbar">
      <button onclick="go('home')">‹ もどる</button>
      <span class="sp"></span>
      <button class="show-btn" id="showToggle" onclick="toggleShow()">👁 見せる表示</button>
    </div>
    <div class="hd" style="margin-top:8px">
      <div class="hd-label" id="ldName">—</div>
      <div class="hd-label" style="margin-top:8px">残債</div>
      <div class="hd-amount" id="ldRemain">¥0</div>
      <div class="bar"><i id="ldBar"></i></div>
      <div class="bar-row"><span id="ldPct">完了 0%</span><span id="ldTotal">—</span></div>
    </div>
    <div class="body">
      <div class="rule" id="ldRule">
        <div class="rl">返済ルール</div>
        <div class="rv" id="ldRuleV">—</div>
        <div class="rn" id="ldRuleN"></div>
      </div>

      <div class="quick" id="ldQuick">
        <button class="qbtn q-red" onclick="openPay('extra')"><span class="qi">⚡</span>臨時返済</button>
        <button class="qbtn q-blue" onclick="openPay('month')"><span class="qi">＋</span>返済を記録</button>
        <button class="qbtn q-green" onclick="openLender(true)"><span class="qi">⚙</span>編集</button>
      </div>

      <div class="est" id="ldEst">
        <span class="ei">📅</span>
        <div><div class="el" id="ldEstL">完済予定の目安</div><div class="ev" id="ldEstV"></div></div>
      </div>

      <div class="sec-h"><h2>計画 vs 実績</h2><span class="note">予定どおり進行中か</span></div>
      <div class="card" style="padding:4px 14px 8px"><div class="tbl" id="ldPlan"></div></div>

      <div class="sec-h"><h2>返済履歴</h2><span class="note" id="ldHistNote">編集・削除OK</span></div>
      <div class="card" style="padding:4px 14px"><div id="ldHist"></div></div>
    </div>
  </div>

  <!-- ===== BUSINESS PLAN ===== -->
  <div class="screen" id="s-biz">
    <div class="tbar"><button onclick="go('home')">‹ もどる</button></div>
    <div class="hd" style="margin-top:8px">
      <div class="hd-title">パーソナル事業の成長計画</div>
      <div class="hd-sub" style="margin-top:8px">売上が伸びるほど、返済は前倒しできます</div>
    </div>
    <div class="body">
      <div class="sec-h"><h2>売上見込み</h2><span class="note">右肩上がりを描く</span></div>
      <div class="card" style="padding:14px"><div class="chart" id="bizChart"></div></div>

      <div class="sec-h"><h2>月ごとの見込みを入力</h2><span class="note">数字は自由に編集</span></div>
      <div class="card" style="padding:4px 14px 10px"><div id="bizInputs"></div>
        <button class="add" style="margin-top:10px" onclick="addBizMonth()">＋ 月を追加</button>
      </div>

      <div class="rule" style="margin-top:16px">
        <div class="rl">この計画で伝わること</div>
        <div class="rv">売上が伸びる → 返済の余力が増える → 早く返せる</div>
        <div class="rn">最低でも固定額は必ず返済、伸びた分は前倒しに回します</div>
      </div>
    </div>
  </div>
</div>

<!-- ===== MODAL ===== -->
<div class="mask" id="mask"><div class="sheet" id="sheet"></div></div>

<script>
/* ---------- storage (fallback for preview) ---------- */
const Store=(()=>{
  let ok=false;try{localStorage.setItem('__t','1');localStorage.removeItem('__t');ok=true;}catch(e){}
  const mem={};
  return{
    get:k=>ok?localStorage.getItem(k):(mem[k]??null),
    set:(k,v)=>{ok?localStorage.setItem(k,v):mem[k]=v;},
    ok
  };
})();
const KEY='saimu_v1';
let data=load();

function load(){
  const raw=Store.get(KEY);
  if(raw){try{return JSON.parse(raw);}catch(e){}}
  return seed();
}
function save(){Store.set(KEY,JSON.stringify(data));}

function seed(){
  return {
    lenders:[{
      id:id(),name:'Aさん',total:12000000,method:'link',fixed:50000,rate:30,
      payments:[
        {id:id(),ym:'2026-07',amount:50000,type:'fix',memo:'固定返済'},
        {id:id(),ym:'2026-08',amount:50000,type:'fix',memo:'固定返済'},
        {id:id(),ym:'2026-09',amount:50000,type:'fix',memo:'固定返済'},
        {id:id(),ym:'2026-10',amount:50000,type:'fix',memo:'固定返済'},
        {id:id(),ym:'2026-11',amount:50000,type:'fix',memo:'固定返済'},
        {id:id(),ym:'2026-12',amount:50000,type:'fix',memo:'固定返済'},
      ]
    }],
    biz:[
      {ym:'2026-07',sales:0},{ym:'2026-08',sales:50000},{ym:'2026-09',sales:120000},
      {ym:'2026-10',sales:200000},{ym:'2026-11',sales:300000},{ym:'2026-12',sales:400000}
    ],
    cheers:['人は出来ないことで悩まない'],
  };
}
function id(){return Math.random().toString(36).slice(2,9);}

/* ---------- helpers ---------- */
const yen=n=>'¥'+Math.round(n).toLocaleString('ja-JP');
const esc=s=>String(s).replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
const paid=l=>l.payments.reduce((s,p)=>s+(+p.amount||0),0);
const remain=l=>Math.max(0,l.total-paid(l));
const pct=l=>l.total>0?Math.min(100,paid(l)/l.total*100):0;
const ymLabel=ym=>{const[y,m]=ym.split('-');return y+'/'+(+m);};
const AV=['var(--green)','var(--blue)','var(--red)','#7C6BD1','#E08A2B'];

let curLender=null, showMode=false;

/* ---------- nav ---------- */
function go(s){
  showMode=false;updateShowBanner();
  document.querySelectorAll('.screen').forEach(e=>e.classList.remove('active'));
  document.getElementById('s-'+s).classList.add('active');
  window.scrollTo(0,0);
}

/* ---------- HOME ---------- */
function renderHome(){
  const totalRemain=data.lenders.reduce((s,l)=>s+remain(l),0);
  const totalAll=data.lenders.reduce((s,l)=>s+l.total,0);
  document.getElementById('homeTotal').innerHTML='<span class="yen">¥</span>'+Math.round(totalRemain).toLocaleString('ja-JP');
  document.getElementById('homeSub').textContent='借入'+data.lenders.length+'件 ／ 総額 '+yen(totalAll);

  const overall=totalAll>0?(totalAll-totalRemain)/totalAll*100:0;
  setCheer(overall);

  const list=document.getElementById('lenderList');
  if(!data.lenders.length){list.innerHTML='<div class="empty">借入先がまだありません。<br>「＋ 借入先を追加」から登録してください。</div>';return;}
  list.innerHTML=data.lenders.map((l,i)=>{
    const p=pct(l).toFixed(1);
    const tag=l.method==='link'?'<span class="tag l-link">売上連動＋固定</span>':'<span class="tag l-fix">固定のみ</span>';
    return `<button class="lender" onclick="openDetail('${l.id}')">
      <span class="av" style="background:${AV[i%AV.length]}">${esc(l.name.slice(0,1))}</span>
      <div class="mid"><div class="nm">${esc(l.name)}</div>${tag}</div>
      <div class="rt"><div class="rm">${yen(remain(l))}</div><div class="pc">完了 ${p}%</div></div>
    </button>`;
  }).join('');
}
function setCheer(p){
  const words=data.cheers&&data.cheers.length?data.cheers:['人は出来ないことで悩まない'];
  document.getElementById('cheer1').textContent=words[Math.floor(Math.random()*words.length)];
  let m;
  if(p<=0)m='まずは第一歩。ここから積み上げよう。';
  else if(p<25)m='動き出してる。残りは1ヶ月ずつ削るだけ。';
  else if(p<50)m='いいペース。折り返しが見えてきた。';
  else if(p<75)m='半分以上クリア。ゴールは近い。';
  else if(p<100)m='ラストスパート。あと少しで完済。';
  else m='完済おめでとう。やりきった。';
  document.getElementById('cheer2').textContent=m;
}

/* ---------- DETAIL ---------- */
function openDetail(lid){curLender=lid;renderDetail();go('lender');}
function renderDetail(){
  const l=data.lenders.find(x=>x.id===curLender);if(!l)return go('home');
  document.getElementById('ldName').textContent=l.name+' さま';
  document.getElementById('ldRemain').innerHTML='<span class="yen">¥</span>'+Math.round(remain(l)).toLocaleString('ja-JP');
  const p=pct(l);
  document.getElementById('ldBar').style.width=Math.max(2,p)+'%';
  document.getElementById('ldPct').textContent='実績 '+p.toFixed(1)+'%';
  document.getElementById('ldTotal').textContent='総額 '+yen(l.total);

  if(l.method==='link'){
    document.getElementById('ldRuleV').textContent='パーソナル売上の'+l.rate+'％ ＋ 固定'+yen(l.fixed)+'／月';
    document.getElementById('ldRuleN').textContent='売上が伸びるほど返済が早まる仕組みです';
  }else{
    document.getElementById('ldRuleV').textContent='毎月 固定'+yen(l.fixed)+' を返済';
    document.getElementById('ldRuleN').textContent='事業が伸びれば、前倒しで早く返せます';
  }

  // completion estimate (fixed-only baseline)
  const r=remain(l);
  if(r<=0){document.getElementById('ldEstL').textContent='完済しました';document.getElementById('ldEstV').textContent='お疲れさまでした';}
  else if(l.fixed>0){
    const months=Math.ceil(r/l.fixed);
    const yrs=Math.floor(months/12),mo=months%12;
    document.getElementById('ldEstL').textContent='固定だけなら 約'+(yrs>0?yrs+'年':'')+(mo>0?mo+'ヶ月':'')+'で完済';
    document.getElementById('ldEstV').textContent='売上連動が乗れば、ここから前倒しできます';
  }else{
    document.getElementById('ldEstL').textContent='完済予定';document.getElementById('ldEstV').textContent='返済を記録すると目安が出ます';
  }

  // plan vs actual (last up to 6 records)
  const rows=[...l.payments].sort((a,b)=>a.ym<b.ym?-1:1).slice(-6);
  const plan=document.getElementById('ldPlan');
  if(!rows.length){plan.innerHTML='<div class="empty">まだ返済記録がありません。</div>';}
  else{
    let h='<div class="th"><span class="c-m">月</span><span class="c-p">予定</span><span class="c-a">実績</span><span class="c-j">判定</span></div>';
    rows.forEach(p=>{
      let planned=l.fixed;
      if(l.method==='link'){const b=data.biz.find(x=>x.ym===p.ym);const sales=b?b.sales:0;planned=l.fixed+Math.round(sales*l.rate/100);}
      const okFlag=(+p.amount)>=planned;
      h+=`<div class="tr"><span class="c-m">${ymLabel(p.ym)}</span><span class="c-p">${yen(planned)}</span><span class="c-a">${yen(p.amount)}</span><span class="c-j ${okFlag?'ok':'miss'}">${okFlag?'✓':'△'}</span></div>`;
    });
    plan.innerHTML=h;
  }

  // history
  const hist=[...l.payments].sort((a,b)=>a.ym<b.ym?1:-1);
  const hd=document.getElementById('ldHist');
  if(!hist.length){hd.innerHTML='<div class="empty">記録なし</div>';}
  else{
    hd.innerHTML=hist.map(p=>{
      const ex=p.type==='extra';
      return `<div class="hrow">
        <span class="hbadge ${ex?'hb-extra':'hb-fix'}">${ex?'⚡':'↓'}</span>
        <div class="hm"><div class="h1">${ymLabel(p.ym)} ${esc(p.memo||(ex?'臨時返済':'返済'))}</div><div class="h2">${ex?'臨時':'定例'}</div></div>
        <span class="ha ${ex?'extra':'fix'}">−${yen(p.amount)}</span>
        ${showMode?'':`<button class="hdots" onclick="openPayEdit('${p.id}')">⋮</button>`}
      </div>`;
    }).join('');
  }
  updateShowUI();
}
function updateShowUI(){
  const q=document.getElementById('ldQuick');
  q.style.display=showMode?'none':'flex';
  document.getElementById('ldHistNote').textContent=showMode?'相手に見せる表示':'編集・削除OK';
  const t=document.getElementById('showToggle');
  t.classList.toggle('on',showMode);
  t.textContent=showMode?'✕ 表示を戻す':'👁 見せる表示';
}
function toggleShow(){showMode=!showMode;updateShowBanner();renderDetail();window.scrollTo(0,0);}
function updateShowBanner(){document.getElementById('showBanner').classList.toggle('on',showMode);}

/* ---------- BUSINESS ---------- */
function renderBiz(){
  const max=Math.max(1,...data.biz.map(b=>b.sales));
  document.getElementById('bizChart').innerHTML=data.biz.map(b=>
    `<div class="col"><div class="bb" style="height:${Math.max(3,b.sales/max*120)}px"></div><div class="cl">${ymLabel(b.ym)}</div></div>`
  ).join('');
  document.getElementById('bizInputs').innerHTML=data.biz.map((b,i)=>
    `<div class="biz-input"><span class="bm">${ymLabel(b.ym)}</span>
      <input type="number" inputmode="numeric" value="${b.sales}" onchange="setBiz(${i},this.value)" placeholder="売上">
      <button class="hdots" onclick="delBiz(${i})">⋮</button></div>`
  ).join('');
}
function setBiz(i,v){data.biz[i].sales=+v||0;save();renderBiz();}
function delBiz(i){data.biz.splice(i,1);save();renderBiz();}
function addBizMonth(){
  let ym='2027-01';
  if(data.biz.length){const last=data.biz[data.biz.length-1].ym;let[y,m]=last.split('-').map(Number);m++;if(m>12){m=1;y++;}ym=y+'-'+String(m).padStart(2,'0');}
  data.biz.push({ym,sales:0});save();renderBiz();
}

/* ---------- MODALS ---------- */
function openModal(html){document.getElementById('sheet').innerHTML=html;document.getElementById('mask').classList.add('open');}
function closeModal(){document.getElementById('mask').classList.remove('open');}
document.getElementById('mask').addEventListener('click',e=>{if(e.target.id==='mask')closeModal();});

let lForm={};
function openLender(edit){
  if(edit){const l=data.lenders.find(x=>x.id===curLender);lForm={...l};}
  else lForm={id:null,name:'',total:'',method:'fix',fixed:'',rate:30};
  renderLenderForm();
}
function renderLenderForm(){
  const f=lForm,isLink=f.method==='link';
  openModal(`
    <h3>${f.id?'借入先を編集':'借入先を追加'}</h3>
    <div class="fld"><label>名前（相手）</label><input id="f-name" value="${esc(f.name||'')}" placeholder="例：Aさん"></div>
    <div class="fld"><label>借入総額</label><input id="f-total" type="number" inputmode="numeric" value="${f.total||''}" placeholder="例：12000000"></div>
    <div class="fld"><label>返済方式</label>
      <div class="seg">
        <button class="${!isLink?'on':''}" onclick="setMethod('fix')">固定のみ</button>
        <button class="${isLink?'on':''}" onclick="setMethod('link')">売上連動＋固定</button>
      </div>
    </div>
    <div class="fld"><label>固定返済額（毎月）</label><input id="f-fixed" type="number" inputmode="numeric" value="${f.fixed||''}" placeholder="例：50000"></div>
    ${isLink?`<div class="fld"><label>売上連動の割合（％）</label><input id="f-rate" type="number" inputmode="numeric" value="${f.rate||30}" placeholder="30"><div class="hint">パーソナル売上のこの％を、固定額に上乗せして返済します</div></div>`:''}
    <div class="btn-row">
      ${f.id?'<button class="btn btn-del" onclick="delLender()">削除</button>':''}
      <button class="btn btn-main" onclick="saveLender()">保存</button>
    </div>
    <div class="btn-row"><button class="btn btn-ghost" onclick="closeModal()">とじる</button></div>
  `);
}
function setMethod(m){captureLForm();lForm.method=m;renderLenderForm();}
function captureLForm(){
  const g=i=>document.getElementById(i);
  if(g('f-name'))lForm.name=g('f-name').value;
  if(g('f-total'))lForm.total=g('f-total').value;
  if(g('f-fixed'))lForm.fixed=g('f-fixed').value;
  if(g('f-rate'))lForm.rate=g('f-rate').value;
}
function saveLender(){
  captureLForm();
  const f=lForm;
  if(!f.name.trim()){alert('名前を入力してください');return;}
  const obj={name:f.name.trim(),total:+f.total||0,method:f.method,fixed:+f.fixed||0,rate:+f.rate||0};
  if(f.id){const l=data.lenders.find(x=>x.id===f.id);Object.assign(l,obj);}
  else{data.lenders.push({id:id(),payments:[],...obj});}
  save();closeModal();renderHome();if(f.id)renderDetail();
}
function delLender(){
  if(!confirm('この借入先を削除しますか？履歴も消えます。'))return;
  data.lenders=data.lenders.filter(x=>x.id!==lForm.id);save();closeModal();renderHome();go('home');
}

let pForm={};
function openPay(kind){
  const ym=new Date().toISOString().slice(0,7);
  pForm={id:null,ym,amount:'',type:kind==='extra'?'extra':'fix',memo:''};
  if(kind!=='extra'){const l=data.lenders.find(x=>x.id===curLender);pForm.amount=l?l.fixed:'';}
  renderPayForm(kind==='extra'?'臨時返済を記録':'返済を記録');
}
function openPayEdit(pid){
  const l=data.lenders.find(x=>x.id===curLender);const p=l.payments.find(x=>x.id===pid);
  pForm={...p};renderPayForm('返済を編集');
}
function renderPayForm(title){
  const p=pForm,ex=p.type==='extra';
  openModal(`
    <h3>${title}</h3>
    <div class="fld"><label>対象の年月</label><input id="p-ym" type="month" value="${p.ym}"></div>
    <div class="fld"><label>返済額</label><input id="p-amt" type="number" inputmode="numeric" value="${p.amount||''}" placeholder="例：50000"></div>
    <div class="fld"><label>種類</label>
      <div class="seg">
        <button class="${!ex?'on':''}" onclick="setPType('fix')">定例</button>
        <button class="${ex?'on':''}" onclick="setPType('extra')">臨時（大きな額）</button>
      </div>
    </div>
    <div class="fld"><label>メモ（任意）</label><input id="p-memo" value="${esc(p.memo||'')}" placeholder="例：ボーナスから"></div>
    <div class="btn-row">
      ${p.id?'<button class="btn btn-del" onclick="delPay()">削除</button>':''}
      <button class="btn btn-main" onclick="savePay()">保存</button>
    </div>
    <div class="btn-row"><button class="btn btn-ghost" onclick="closeModal()">とじる</button></div>
  `);
}
function setPType(t){capturePForm();pForm.type=t;renderPayForm(pForm.id?'返済を編集':(t==='extra'?'臨時返済を記録':'返済を記録'));}
function capturePForm(){
  const g=i=>document.getElementById(i);
  if(g('p-ym'))pForm.ym=g('p-ym').value;
  if(g('p-amt'))pForm.amount=g('p-amt').value;
  if(g('p-memo'))pForm.memo=g('p-memo').value;
}
function savePay(){
  capturePForm();const p=pForm;
  if(!p.amount||+p.amount<=0){alert('返済額を入力してください');return;}
  const l=data.lenders.find(x=>x.id===curLender);
  const obj={ym:p.ym,amount:+p.amount,type:p.type,memo:p.memo||(p.type==='extra'?'臨時返済':'返済')};
  if(p.id){Object.assign(l.payments.find(x=>x.id===p.id),obj);}
  else{l.payments.push({id:id(),...obj});}
  save();closeModal();renderDetail();
}
function delPay(){
  if(!confirm('この記録を削除しますか？'))return;
  const l=data.lenders.find(x=>x.id===curLender);
  l.payments=l.payments.filter(x=>x.id!==pForm.id);
  save();closeModal();renderDetail();
}

/* ---------- SETTINGS ---------- */
function openSettings(){
  openModal(`
    <h3>設定</h3>
    <div class="fld"><label>励ましの言葉（1行に1つ）</label>
      <textarea id="s-cheers" style="width:100%;min-height:110px;padding:11px 12px;border:1px solid var(--line);border-radius:11px;background:#fafcfb;font-family:inherit;font-size:1rem;resize:vertical">${esc((data.cheers||[]).join('\n'))}</textarea>
      <div class="hint">ホームでランダムに表示されます</div>
    </div>
    <div class="btn-row"><button class="btn btn-main" onclick="saveCheers()">保存</button></div>
    <div class="btn-row"><button class="btn btn-ghost" onclick="closeModal()">とじる</button></div>
    <div class="btn-row"><button class="btn btn-del" onclick="resetAll()">すべてのデータを初期化</button></div>
    <div class="hint" style="text-align:center">${Store.ok?'データはこの端末に保存されています':'※プレビュー環境では保存されません（ダウンロード後は保存されます）'}</div>
  `);
}
function saveCheers(){
  const t=document.getElementById('s-cheers').value;
  data.cheers=t.split('\n').map(s=>s.trim()).filter(Boolean);
  if(!data.cheers.length)data.cheers=['人は出来ないことで悩まない'];
  save();closeModal();renderHome();
}
function resetAll(){
  if(!confirm('すべてのデータを消して初期状態に戻します。よろしいですか？'))return;
  data=seed();save();closeModal();renderHome();go('home');
}

/* ---------- boot ---------- */
function boot(){renderHome();renderBiz();}
// re-render biz when entering
const _go=go;
go=function(s){_go(s);if(s==='biz')renderBiz();if(s==='home')renderHome();};
boot();
if('serviceWorker' in navigator){window.addEventListener('load',()=>navigator.serviceWorker.register('sw.js').catch(()=>{}));}

/* ---------- PWA: service worker ---------- */
if('serviceWorker' in navigator){
  window.addEventListener('load',()=>{navigator.serviceWorker.register('sw.js').catch(()=>{});});
}
</script>
